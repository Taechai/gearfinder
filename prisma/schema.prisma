generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Strores user information
model User {
    id                 Int       @id @default(autoincrement())
    fullName           String
    email              String    @unique
    passwordHash       String
    projectsOwned      Project[] @relation("OwnedProjects")
    accessibleProjects Project[] @relation("SharedProjects")
}

// Manages project-related data
model Project {
    id                 Int                  @id @default(autoincrement())
    projectName        String               @unique
    createdAt          DateTime             @default(now())
    owner              User                 @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    ownerId            Int
    sharedWith         User[]               @relation("SharedProjects")
    files              File[]               @relation("FilesInProject")
    machineLearningJob MachineLearningJob[]
}

// Tracks .xtf files and their metadata
model File {
    id                     Int                      @id @default(autoincrement())
    filePath               String                   @unique
    fileName               String
    uploadedAt             DateTime                 @default(now())
    project                Project                  @relation("FilesInProject", fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    projectId              Int
    reconstructedImage     ReconstructedImage?      @relation("CorrespondingImage")
    imageReconstructionJob ImageReconstructionJob[]
}

// Stores information about the reconstructed images
model ReconstructedImage {
    id              Int          @id @default(autoincrement())
    imagePath       String
    reconstructedAt DateTime     @default(now())
    file            File         @relation("CorrespondingImage", fields: [fileId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    fileId          Int          @unique
    annotations     Annotation[] @relation("AnnotationsInImage")
}

model Annotation {
    id          String             @id
    boundingBox Json
    coordinate  Json
    className   String
    image       ReconstructedImage @relation("AnnotationsInImage", fields: [imageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    imageId     Int
    createdAt   DateTime           @default(now())
    status      String             @default("Not Found")
}

// Image reconstruction jobs
model ImageReconstructionJob {
    id           Int       @id @default(autoincrement())
    file         File      @relation(fields: [fileId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    fileId       Int
    status       String    @default("pending") // Status of the job: pending, in progress, completed, failed
    createdAt    DateTime  @default(now())
    completedAt  DateTime?
    errorMessage String?
}

model MachineLearningJob {
    id           Int       @id @default(autoincrement())
    project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    projectId    Int
    status       String    @default("pending") // Status of the job: pending, in progress, completed, failed
    createdAt    DateTime  @default(now())
    completedAt  DateTime?
    errorMessage String?
}
